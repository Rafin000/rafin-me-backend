# Copy to .env and fill in real values. Do NOT commit .env.
APP_SETTINGS=project.server.config.ProductionConfig
FLASK_APP=manage.py

# Postgres
POSTGRES_SERVER_NAME=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=blogdb

# App secrets
SECRET_KEY=generate-a-long-random-string
API_KEY=generate-a-long-random-string

# Mail (Gmail app password)
MAIL_USERNAME=you@example.com
MAIL_PASSWORD=app-password-here
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=465
MAIL_USE_SSL=true
MAIL_USE_TLS=false
